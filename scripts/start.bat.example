@echo off
:: SZABLON STARTOWY - Skopiuj ten plik jako start.bat i ustaw własny pieprz!
set SHOP_APP_PEPPER=ZmienTenPieprzNaWlasnySekret123!

:: Domyślne dane logowania dla pierwszego administratora
set SHOP_DEFAULT_ADMIN_USER=admin
set SHOP_DEFAULT_ADMIN_PASS=Admin1234!

:: Parametry połączenia z bazą MySQL (każdy ma sensowny default w kodzie)
:: APP_DB_HOST=localhost
:: APP_DB_PORT=3306
:: APP_DB_NAME=tickets
:: APP_DB_USER=root
:: APP_DB_PASS=

:: Zależność mysql-connector-j (lib/mysql-connector-j-9.3.0.jar) musi być
:: dostępna obok zbudowanego .jar-a (Class-Path w MANIFEST.MF wskazuje ją
:: relatywnie do pliku wykonywalnego).

for /f "tokens=2 delims=:" %%a in ('chcp') do set "c=%%a"
chcp 65001 > nul
java -Dfile.encoding=UTF-8 -jar ..\out\artifacts\ProgramowanieObiektoweProjekt_jar\ProgramowanieObiektoweProjekt.jar
chcp %c: =% > nul
