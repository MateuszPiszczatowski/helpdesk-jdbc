@echo off
:: SZABLON STARTOWY - Skopiuj ten plik jako start.bat i ustaw własny pieprz!
set SHOP_APP_PEPPER=ZmienTenPieprzNaWlasnySekret123!

:: Domyślne dane logowania dla pierwszego administratora
set SHOP_DEFAULT_ADMIN_USER=admin
set SHOP_DEFAULT_ADMIN_PASS=Admin1234!

:: Tryb developerski (domyślnie false). Gdy =true, ConsoleIo używa fallbacku
:: na stdin do uruchamiania pod debuggerem IDE (hasło NIE jest maskowane). Przy
:: false brak prawdziwej konsoli kończy się czytelnym komunikatem zamiast
:: fallbacku. Ustaw na true tylko na potrzeby developmentu.
set SHOP_APP_DEV_MODE=false

:: Parametry połączenia z bazą MySQL (każdy ma sensowny default w kodzie)
:: APP_DB_HOST=localhost
:: APP_DB_PORT=3306
:: APP_DB_NAME=tickets
:: APP_DB_USER=root
:: APP_DB_PASS=

:: Zależność mysql-connector-j jest wbudowana w artefakt .jar (fat jar),
:: więc nic nie musi leżeć obok pliku wykonywalnego.

for /f "tokens=2 delims=:" %%a in ('chcp') do set "c=%%a"
chcp 65001 > nul
java -Dfile.encoding=UTF-8 -jar ..\out\artifacts\ProgramowanieObiektoweProjekt_jar\ProgramowanieObiektoweProjekt.jar
chcp %c: =% > nul
